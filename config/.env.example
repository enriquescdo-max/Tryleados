# LeadOS Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# Database
LEADOS_DB_URL=postgresql://user:password@localhost:5432/leados

# CRM
HUBSPOT_ACCESS_TOKEN=your_hubspot_token_here
# OR for Salesforce:
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_USERNAME=
# SALESFORCE_PASSWORD=

# Research
TAVILY_API_KEY=your_tavily_key_here
# Alternative: PERPLEXITY_API_KEY=

# Email delivery
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=yourname@yourdomain.com
SENDGRID_FROM_NAME=Your Name

# Slack alerts
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_ALERT_CHANNEL=#sales-hot-leads

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Scheduling
SCORING_CRON=0 6 * * *        # 6 AM daily
REPORT_CRON=0 9 * * 5         # 9 AM every Friday
